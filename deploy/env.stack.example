# Copiar para .env na raiz ou usar: docker compose --env-file deploy/env.stack.example
#
# --- Supabase (obrigatório) ---
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...
# URL pública onde o browser chama as funções (reverse proxy → serviço `functions` na porta 3100)
# Ex.: https://api.seudominio.com/functions/v1  (o path /functions/v1 deve chegar ao Node)
VITE_SUPABASE_FUNCTIONS_URL=https://api.seudominio.com/functions/v1

# --- Runtime Node (services/functions-runtime) ---
# forward = proxy transparente para Supabase Edge (paridade imediata; recomendado na fase 1)
# stub = 501 até implementação Node completa
FUNCTIONS_RUNTIME_MODE=forward
# Origem do projeto Supabase (sem /functions/v1) — usado só em modo forward
FUNCTIONS_FORWARD_ORIGIN=https://xxxx.supabase.co

# Opcional: build frontend
VITE_EXTERNAL_MEDIA_STORAGE=false
