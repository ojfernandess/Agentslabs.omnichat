# Build SPA (Vite) — contexto: raiz do repositório
# docker build -f deploy/Dockerfile -t agentslabs-web .

FROM node:22-alpine AS builder
WORKDIR /app

COPY package.json package-lock.json* ./
RUN npm ci --no-audit --no-fund || npm install --no-audit --no-fund

COPY . .

# Args de build (EasyPanel / CI)
ARG VITE_SUPABASE_URL=""
ARG VITE_SUPABASE_PUBLISHABLE_KEY=""
ARG VITE_SUPABASE_PROJECT_ID=""
ARG VITE_DEPLOYMENT_MODE=supabase
ARG VITE_SUPABASE_FUNCTIONS_URL=""
ARG VITE_PUBLIC_APP_URL=""
ARG META_APP_ID=""
ARG VITE_META_APP_ID=""
ARG VITE_EXTERNAL_MEDIA_STORAGE=""
ARG VITE_EXTERNAL_MEDIA_UPLOAD_URL=""

ENV VITE_SUPABASE_URL=$VITE_SUPABASE_URL
ENV VITE_SUPABASE_PUBLISHABLE_KEY=$VITE_SUPABASE_PUBLISHABLE_KEY
ENV VITE_SUPABASE_PROJECT_ID=$VITE_SUPABASE_PROJECT_ID
ENV VITE_DEPLOYMENT_MODE=$VITE_DEPLOYMENT_MODE
ENV VITE_SUPABASE_FUNCTIONS_URL=$VITE_SUPABASE_FUNCTIONS_URL
ENV VITE_PUBLIC_APP_URL=$VITE_PUBLIC_APP_URL
ENV META_APP_ID=$META_APP_ID
ENV VITE_META_APP_ID=$VITE_META_APP_ID
ENV VITE_EXTERNAL_MEDIA_STORAGE=$VITE_EXTERNAL_MEDIA_STORAGE
ENV VITE_EXTERNAL_MEDIA_UPLOAD_URL=$VITE_EXTERNAL_MEDIA_UPLOAD_URL

RUN npm run build

FROM nginx:alpine AS runner
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/dist /usr/share/nginx/html
EXPOSE 8080
CMD ["nginx", "-g", "daemon off;"]
