# Copie estes nomes para o Easypanel → projeto → Environment (ou ficheiro .env na raiz do clone).
# Obrigatório: o Docker build (npm run build) deve receber estes valores — não só o container em runtime.
# Se a página ficar em branco, as VITE_* não entraram no bundle; faça rebuild após definir as variáveis.
#
# Obrigatórios para o build Vite (SPA):
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Opcionais (ver .env.example)
# Base das Edge Functions: https://<ref>.supabase.co/functions/v1 (SEM nome de função no fim).
# Se colar .../functions/v1/meta-whatsapp-webhook, o app chama a função errada (ex.: erro "channel_id obrigatório").
VITE_SUPABASE_FUNCTIONS_URL=
VITE_DEPLOYMENT_MODE=easypanel
META_APP_ID=
VITE_PUBLIC_APP_URL=https://seu-dominio.com
VITE_INTERNAL_HOOK_SECRET=
VITE_EXTERNAL_MEDIA_STORAGE=
VITE_EXTERNAL_MEDIA_UPLOAD_URL=
WEB_PORT=8080
# Só para perfil migrate (db-init):
# DATABASE_URL=postgresql://postgres:...@db:5432/postgres
