# Copie para .env e preencha (nunca commite .env)
# Build Docker: docker compose lê estes valores para embutir no bundle Vite

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_SUPABASE_PROJECT_ID=

# Opcional: base URL das Edge Functions (sem barra final).
# Vazio = usa {VITE_SUPABASE_URL}/functions/v1 (Supabase Cloud ou stack unificada).
# Preencha se as funções estiverem noutro host (ex.: https://api.seudominio.com/functions/v1)
VITE_SUPABASE_FUNCTIONS_URL=

# Mídia (imagens, áudio, vídeo, PDF) no MinIO/S3 do Easypanel em vez do Storage do Supabase Cloud:
# - true = uploads via Edge Function `upload-media` (multipart) para S3
# - Defina também secrets S3_MEDIA_* nas funções (upload-media, webhooks, process-media) — ver docs/DEPLOYMENT_ARCHITECTURE.md
VITE_EXTERNAL_MEDIA_STORAGE=false
# Opcional: só o upload de mídia noutra base (ex.: https://api.seudominio.com/functions/v1). Vazio = igual a VITE_SUPABASE_FUNCTIONS_URL.
VITE_EXTERNAL_MEDIA_UPLOAD_URL=

# supabase | selfhosted — apenas informativo / documentação
VITE_DEPLOYMENT_MODE=supabase

# Opcional — Meta / WhatsApp (OAuth; mesmo App ID que nas Edge Functions)
META_APP_ID=
VITE_PUBLIC_APP_URL=http://localhost:8080
VITE_INTERNAL_HOOK_SECRET=

# Porta do compose (docker-compose.yml)
WEB_PORT=8080

# Migrações (scripts/db-migrate.sh ou container db-init)
# DATABASE_URL=postgresql://postgres:...@db:5432/postgres
