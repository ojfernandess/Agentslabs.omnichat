# Copie para .env e preencha (nunca commite .env)
# Build Docker: docker compose lê estes valores para embutir no bundle Vite

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_SUPABASE_PROJECT_ID=

# Opcional — Meta / WhatsApp
VITE_META_APP_ID=
VITE_PUBLIC_APP_URL=http://localhost:8080
VITE_META_OAUTH_REDIRECT_URI=
VITE_META_EMBEDDED_SIGNUP_CONFIG_ID=
VITE_META_GRAPH_VERSION=v21.0
VITE_META_EMBEDDED_TOKEN_REDIRECT_URI=
VITE_INTERNAL_HOOK_SECRET=

# Porta do compose (docker-compose.yml)
WEB_PORT=8080
