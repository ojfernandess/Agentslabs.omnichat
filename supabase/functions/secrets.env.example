# Copie para o painel: Project Settings → Edge Functions → Secrets
# ou: supabase secrets set KEY=value
#
# ⚠️ Supabase Cloud: o .env do frontend (Vite) NÃO injeta estas variáveis nas Edge Functions.
#    Tem de as definir no painel ou com `supabase secrets set`. Ver:
#    docs/SUPABASE_CLOUD_MINIO_SECRETS.md

SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
INTERNAL_HOOK_SECRET=gere_um_segredo_longo_aleatorio
# Obrigatório para meta-oauth-exchange (troca do code OAuth). O .env do Vite NÃO chega às funções na cloud.
META_APP_ID=id_do_app_meta_mesmo_do_login_facebook
META_APP_SECRET=app_secret_do_meta_developers_facebook
# Frontend (build Vite): META_APP_ID + opcional VITE_META_EMBEDDED_CONFIG_ID (Configuration ID WhatsApp Embedded Signup, como Chatwoot WHATSAPP_CONFIGURATION_ID)
# Alinhar com VITE_META_GRAPH_VERSION no frontend (SDK FB.init). Predefinido v22.0.
META_GRAPH_VERSION=v22.0
TELEGRAM_WEBHOOK_SECRET=opcional_secret_token_telegram
# WhatsApp Evolution API: URL base + apikey + instance ficam em channels.config.evolution (UI).
# Webhook: deploy evolution-whatsapp-webhook e registe POST /webhook/set/{instance} na Evolution.
#
# Webhook Meta — ACK rápido (fila webhook_ingest_jobs; ver docs/SCALING_WEBHOOKS_AND_CAMPAIGNS.md)
# omitido ou true = 200 após enfileirar (recomendado). false = processar na mesma request (debug).
# META_WEBHOOK_FAST_ACK=true
# Worker campanhas: msgs/s (conservador vs limites Meta)
# CAMPAIGN_SEND_PER_SECOND=5

# --- MinIO / S3 no Easypanel (mídia fora do Supabase Storage) ---
# Obrigatórias se usar VITE_EXTERNAL_MEDIA_STORAGE=true ou quiser webhooks a gravarem áudio no MinIO.
# MEDIA_PUBLIC_BASE_URL = URL pública por bucket: ex. https://cdn.seudominio.com
# URLs finais: {MEDIA_PUBLIC_BASE_URL}/{bucket}/{key}  (buckets: message-media, inbox-avatars)
S3_MEDIA_ENDPOINT=https://minio.seudominio.com
S3_MEDIA_REGION=us-east-1
S3_MEDIA_ACCESS_KEY=
S3_MEDIA_SECRET_KEY=
# false = path-style (recomendado MinIO)
S3_MEDIA_FORCE_PATH_STYLE=true
S3_MEDIA_BUCKET_MESSAGE=message-media
S3_MEDIA_BUCKET_INBOX=inbox-avatars
# Opcional: timeout por tentativa de PUT (ms), 5000–120000; predefinido 22000.
# S3_MEDIA_PUT_TIMEOUT_MS=45000
# MinIO inacessível da cloud Supabase (AbortError): upload-media usa só Storage, sem tentar PUT ao S3.
# S3_MEDIA_DISABLE_EDGE_PUT=true
MEDIA_PUBLIC_BASE_URL=https://cdn.seudominio.com
# SUPABASE_ANON_KEY — normalmente injetado pelo Supabase nas Edge Functions

# --- Política de anexos (ver docs/MINIO_MEDIA_ARCHITECTURE.md) ---
# true = limites antigos (10 MB único, GIF, OGG, …). Alinhar com VITE_MEDIA_LEGACY_ATTACHMENTS no frontend.
# MEDIA_LEGACY_ATTACHMENTS=false

# --- media-presign: TTL da URL PUT (segundos), 60–3600; predefinido 900 ---
# MEDIA_PRESIGN_PUT_EXPIRES_SEC=900

# --- minio-media-webhook: preferir segredo dedicado; senão usa INTERNAL_HOOK_SECRET ---
# MINIO_WEBHOOK_SECRET=gere_um_segredo_longo

# --- Scan antivírus opcional (POST multipart campo "file"; 200 = OK) ---
# MEDIA_SCAN_WEBHOOK_URL=https://seu-scanner/scan
# MEDIA_SCAN_WEBHOOK_SECRET=
